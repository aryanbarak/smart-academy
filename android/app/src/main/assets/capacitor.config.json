{
	"appId": "com.fiae.lernplattform",
	"appName": "FIAE Lernplattform",
	"webDir": "dist",
	"server": {
		"androidScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 1500,
			"launchAutoHide": false,
			"backgroundColor": "#0f172a",
			"androidSplashResourceName": "splash",
			"showSpinner": false,
			"splashFullScreen": true,
			"splashImmersive": true
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#0f172a"
		}
	}
}
